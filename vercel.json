{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo 'skip: Flutter web only, no root Python install'",
  "buildCommand": "bash scripts/vercel_build_web.sh",
  "outputDirectory": "mobile/snakebite_rx/build/web",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/proxy/:path*",
      "destination": "https://snakebite-eag1.onrender.com/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
